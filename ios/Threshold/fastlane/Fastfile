default_platform(:ios)

platform :ios do

  before_all do
    setup_ci if ENV['CI']
  end

  desc "Load App Store Connect API key from environment"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )
  end

  desc "Fetch signing certificates and provisioning profiles"
  lane :fetch_certs do
    load_asc_api_key

    match(
      type: "appstore",
      readonly: false,
      force: true,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    )
  end

  desc "One-time setup: generate certs and profiles (run locally)"
  lane :setup_match do
    load_asc_api_key

    match(
      type: "appstore",
      readonly: false,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    )
  end

  desc "Increment build number based on latest TestFlight build"
  lane :increment_build do
    load_asc_api_key

    current_version = get_version_number(
      xcodeproj: "Threshold.xcodeproj",
      target: "Threshold"
    )

    latest_build = latest_testflight_build_number(
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      version: current_version,
      app_identifier: "com.thresholdvote.app"
    )

    increment_build_number(
      xcodeproj: "Threshold.xcodeproj",
      build_number: (latest_build + 1)
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    load_asc_api_key
    fetch_certs
    increment_build

    profile_name = ENV["sigh_com.thresholdvote.app_appstore_profile-name"]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Threshold.xcodeproj",
      team_id: ENV["TEAM_ID"],
      bundle_identifier: "com.thresholdvote.app",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    gym(
      scheme: "Threshold",
      workspace: "../Threshold.xcworkspace",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.thresholdvote.app" => profile_name
        }
      },
      output_directory: "./build",
      output_name: "Threshold.ipa",
      clean: true,
      include_bitcode: false,
      xcargs: "ASSETCATALOG_COMPILER_SKIP_VALIDATIONS=YES"
    )

    pilot(
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      ipa: "./build/Threshold.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: false,
      distribute_external: false,
      changelog: "Build #{get_build_number(xcodeproj: 'Threshold.xcodeproj')} uploaded from CI"
    )
  end

  desc "Build and upload to App Store"
  lane :release do
    load_asc_api_key
    fetch_certs
    increment_build

    profile_name = ENV["sigh_com.thresholdvote.app_appstore_profile-name"]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Threshold.xcodeproj",
      team_id: ENV["TEAM_ID"],
      bundle_identifier: "com.thresholdvote.app",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    gym(
      scheme: "Threshold",
      workspace: "../Threshold.xcworkspace",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.thresholdvote.app" => profile_name
        }
      },
      output_directory: "./build",
      output_name: "Threshold.ipa",
      clean: true,
      include_bitcode: false,
      xcargs: "ASSETCATALOG_COMPILER_SKIP_VALIDATIONS=YES"
    )

    deliver(
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      ipa: "./build/Threshold.ipa",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end
end
